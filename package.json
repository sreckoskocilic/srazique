{
  "name": "srazique",
  "productName": "Srazique",
  "version": "1.0.5",
  "description": "Sraz Rebirth - Strategic board game",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "lint": "eslint main.js scripts/",
    "lint:fix": "eslint main.js scripts/ --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win",
    "build:dir": "electron-builder --dir"
  },
  "keywords": [
    "game",
    "board-game",
    "strategy",
    "electron"
  ],
  "author": "Srecko Skocilic",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "electron": "41.1.0",
    "electron-builder": "26.8.1",
    "eslint": "10.1.0",
    "eslint-plugin-html": "^8.1.4",
    "prettier": "^3.4.0",
    "vitest": "^4.1.0",
    "vm2": "^3.10.5"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "build": {
    "appId": "com.srazique.game",
    "productName": "Srazique",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Srazique_Setup.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "asar": true,
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "questions.enc",
      "scripts/decrypt-questions.js"
    ],
    "compression": "maximum",
    "npmRebuild": false
  },
  "dependencies": {}
}
